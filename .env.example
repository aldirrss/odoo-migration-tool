# Staging database (local PostgreSQL)
STAGING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/odoo_migration_staging

# Encryption key for storing DB connection profiles
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# Migration data filter (transactions from this date onward)
TRANSACTION_DATE_FROM=2026-01-01
